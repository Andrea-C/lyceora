# Database (Neon Postgres in prod)
#
# Local dev without Docker: this repo ships a PGlite-over-TCP stand-in for
# Postgres (packages/db/scripts/dev-server.ts). It speaks the real Postgres
# wire protocol on port 5502 and persists to .superpowers/devdb, so pg.Pool
# and drizzle-kit work against it unmodified.
#   1. pnpm --filter @lyceora/db db:dev      (starts the socket server, logs "ready")
#   2. pnpm --filter @lyceora/db db:migrate  (applies drizzle/*.sql over the socket)
#   3. pnpm dev                              (apps/web, using DATABASE_URL below)
# Copy this file to packages/db/.env (drizzle-kit reads DATABASE_URL from there)
# and to apps/web/.env.local (Next.js reads it from there) with:
#   DATABASE_URL=postgres://postgres:postgres@localhost:5502/postgres
DATABASE_URL=
# Better Auth
BETTER_AUTH_SECRET=
BETTER_AUTH_URL=http://localhost:3000
# Model providers (at least one required)
ANTHROPIC_API_KEY=
OPENAI_API_KEY=
GEMINI_API_KEY=
OPENROUTER_API_KEY=
# Use fake/mock models for keyless local development (test-only)
# LYCEORA_FAKE_MODELS=1
